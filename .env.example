# Next.js
NODE_ENV=development

# Socket.io Server Configuration
# The socket server runs on port 3001 by default
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Redis Configuration (optional - defaults to in-memory storage)
# Uncomment and configure if you want persistent game state
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server Port
PORT=3001
